{
  "name": "bsky-endpoints",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Standalone HTTP/XRPC endpoint reference for Bluesky lexicons (generated from on-network schemas via @atproto/lex, rendered as OpenAPI).",
  "scripts": {
    "seed": "tsx scripts/seed-allowlist.ts",
    "install-lexicons": "node scripts/lex.mjs install",
    "install-lexicons:ci": "node scripts/lex.mjs install --ci",
    "update-lexicons": "node scripts/lex.mjs install --update",
    "build:openapi": "tsx src/build-openapi.ts",
    "build:site": "tsx src/render.ts",
    "build": "npm run install-lexicons:ci && npm run build:openapi && npm run build:site",
    "start": "serve -s out -l tcp://0.0.0.0:${PORT:-3000} --no-port-switching",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@atproto/lex": "^0.1.3",
    "fast-glob": "^3.3.2",
    "serve": "^14.2.6"
  },
  "devDependencies": {
    "@atproto/lexicon": "^0.7.1",
    "@scalar/api-reference": "^1.57.5",
    "openapi-types": "^12.1.3",
    "tsx": "^4.19.0",
    "typescript": "~5.5.0"
  }
}
