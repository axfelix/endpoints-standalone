{
  "id": "tools.ozone.moderation.searchRepos",
  "defs": {
    "main": {
      "type": "query",
      "output": {
        "schema": {
          "type": "object",
          "required": [
            "repos"
          ],
          "properties": {
            "repos": {
              "type": "array",
              "items": {
                "ref": "tools.ozone.moderation.defs#repoView",
                "type": "ref"
              }
            },
            "cursor": {
              "type": "string"
            }
          }
        },
        "encoding": "application/json"
      },
      "parameters": {
        "type": "params",
        "properties": {
          "q": {
            "type": "string"
          },
          "term": {
            "type": "string",
            "description": "DEPRECATED: use 'q' instead"
          },
          "limit": {
            "type": "integer",
            "default": 50,
            "maximum": 100,
            "minimum": 1
          },
          "cursor": {
            "type": "string"
          }
        }
      },
      "description": "Find repositories based on a search term."
    }
  },
  "$type": "com.atproto.lexicon.schema",
  "lexicon": 1
}