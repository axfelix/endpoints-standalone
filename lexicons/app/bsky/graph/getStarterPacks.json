        "required": [
          "uris"
        ],
        "properties": {
          "uris": {
            "type": "array",
            "items": {
              "type": "string",
              "format": "at-uri"
            },
            "maxLength": 25
          }
        }
      },
      "description": "Get views for a list of starter packs."
    }
  },
  "$type": "com.atproto.lexicon.schema",
  "lexicon": 1
}